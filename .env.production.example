# =====================================================================
# ULOV KLIENTY — produkční .env (pro docker compose)
# Zkopírujte jako .env na serveru a vyplňte. NIKDY necommitovat!
#   cp .env.production.example .env
# =====================================================================

# --- Django jádro ---
# Vygenerujte nový klíč:
#   python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
SECRET_KEY=zmente-mne-na-nahodny-dlouhy-retezec
DEBUG=False
# Čárkou oddělené domény, na kterých API běží (bez schématu):
ALLOWED_HOSTS=api.vase-domena.cz

# --- Databáze (PostgreSQL) ---
# Přítomnost DB_NAME přepne backend ze SQLite na PostgreSQL.
DB_NAME=ulov
DB_USER=ulov
DB_PASSWORD=zmente-silne-heslo
DB_HOST=db
DB_PORT=5432

# --- Redis (cache + Celery broker) ---
REDIS_URL=redis://redis:6379/0

# --- E-maily přes Celery (fronta) ---
# false = sync SMTP jako dřív (nouzový rollback)
# true  = maily přes službu `worker` (vyžaduje Redis + běžící worker)
EMAIL_VIA_CELERY=false

# --- CORS / CSRF (domény frontendů salonů) ---
# Čárkou oddělené originy WEBŮ salonů (se schématem https://):
CORS_ALLOWED_ORIGINS=https://salon1.cz,https://salon2.cz
CSRF_TRUSTED_ORIGINS=https://salon1.cz,https://salon2.cz

# --- HTTPS (za Nginx) ---
SECURE_SSL_REDIRECT=True

# --- Administrace salonů ---
SALON_ADMIN_PASSWORD=zmente-silne-heslo

# --- Bunny.net (CDN + úložiště fotek) ---
BUNNY_STORAGE_ZONE=vase-storage-zone
BUNNY_STORAGE_API_KEY=vase-api-heslo
BUNNY_STORAGE_REGION=
BUNNY_CDN_BASE_URL=https://vase-zona.b-cdn.net
BUNNY_STORAGE_PATH_PREFIX=webs

# --- Komprese nahraných obrázků (volitelné) ---
# IMAGE_UPLOAD_MAX_PX=1920
# IMAGE_UPLOAD_JPEG_QUALITY=85
# IMAGE_UPLOAD_WEBP_QUALITY=85

# Staging: všechny odchozí maily na jednu adresu (povinné na stagingu!)
# EMAIL_OVERRIDE_TO=info@ulovklienty.cz
# EMAIL_HOST=smtp.forpsi.com
# EMAIL_PORT=465

# Veřejná URL FLOW (pozvánky / reset hesla)
# FLOW_BASE_URL=https://www.ulovklienty.cz/flow/
# EMAIL_USE_SSL=true
# EMAIL_USE_TLS=false
# EMAIL_HOST_USER=info@vase-domena.cz
# EMAIL_HOST_PASSWORD=heslo-k-schrance
# DEFAULT_FROM_EMAIL=info@vase-domena.cz
# POPTAVKA_EMAIL=poptavky@vase-domena.cz

# --- Logging (pouze stdout → docker logs + Sentry) ---
LOG_LEVEL=INFO

# --- Sentry (volitelné) ---
# SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

# --- GDPR ---
# GDPR_UCHOVAVANI_MESICU=12
