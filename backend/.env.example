# Bunny.net Storage – zkopírujte jako .env a vyplňte hodnoty z dashboardu
# https://dash.bunny.net/storage

# Název Storage Zone (FTP & HTTP API → Username)
BUNNY_STORAGE_ZONE=vase-storage-zone

# Heslo Storage Zone (FTP & HTTP API → Password)
BUNNY_STORAGE_API_KEY=vase-api-heslo

# Region storage (volitelné): např. de, uk, ny – prázdné = hlavní endpoint
BUNNY_STORAGE_REGION=

# URL Pull Zone CDN (Storage → vaše zóna → Linked Hostnames)
# Např. https://vase-zona.b-cdn.net
BUNNY_CDN_BASE_URL=https://vase-zona.b-cdn.net

# Složka ve storage (máte již složku "webs" v file manageru)
BUNNY_STORAGE_PATH_PREFIX=webs

# Komprese nahraných obrázků (hero, galerie, personál, novinky)
# IMAGE_UPLOAD_MAX_PX=1920
# IMAGE_UPLOAD_JPEG_QUALITY=85
# IMAGE_UPLOAD_WEBP_QUALITY=85

# E-mail – Forpsi / Seznam / Gmail …
# Forpsi: smtp.forpsi.com, port 465, SSL=true, TLS=false
# EMAIL_HOST=smtp.forpsi.com
# EMAIL_PORT=465
# EMAIL_USE_SSL=true
# EMAIL_USE_TLS=false
# EMAIL_HOST_USER=info@vase-domena.cz
# EMAIL_HOST_PASSWORD=heslo-k-schrance
# DEFAULT_FROM_EMAIL=info@vase-domena.cz

# Per salon – vlastní schránka pro každý web:
# SALON_1_SMTP_USER=info@salon1.cz
# SALON_1_SMTP_PASSWORD=...
# SALON_1_SMTP_HOST=smtp.forpsi.com
# SALON_1_SMTP_PORT=465
# SALON_1_SMTP_USE_SSL=true
